{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Cygwin: 활성 파일 debug ",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "PATH",
          "value": "C:\\cygwin64\\bin;${env:PATH}"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:\\cygwin64\\bin\\gdb.exe",
      "preLaunchTask": "Cygwin gcc build active file"
    }
  ]
}
